#!/bin/bash
#
# cmd/main — fnOS 进程生命周期入口（管理 server.py 和 mihomo）

PID_FILE="${TRIM_PKGHOME}/.fnproxy-web.pid"

case $1 in
start)
    # 已启动则跳过
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        exit 0
    fi
    # 进入到app目录执行server.py 确保工作目录正确，避免路径问题
    cd ${TRIM_APPDEST}
    WEB_PORT=$(cat "${TRIM_PKGHOME}/.fnproxy-port" 2>/dev/null || echo "8567")
    python3 -u server.py --port "$WEB_PORT" >> clash-web.log 2>&1 &
    echo $! > "$PID_FILE"
    exit 0
    ;;
stop)
    # 关闭 server.py
    if [ -f "$PID_FILE" ]; then
        kill "$(cat "$PID_FILE")" 2>/dev/null
        rm -f "$PID_FILE"
    fi
    # 同步关闭 mihomo
    MIHOMO_PID=$(pgrep -f '/mihomo ' 2>/dev/null)
    if [ -n "$MIHOMO_PID" ]; then
        kill "$MIHOMO_PID" 2>/dev/null
    fi
    exit 0
    ;;
status)
    if [ -f "$PID_FILE" ] && kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "server.py running (PID $(cat "$PID_FILE"))"
        exit 0
    else
        echo "server.py stopped"
        exit 3
    fi
    ;;
*)
    exit 1
    ;;
esac
